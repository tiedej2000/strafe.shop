---
import Layout from '../layouts/Layout.astro';

// Weitere Bilder einfach hier anhaengen
const editorials = [
	'/landingpage/editiorial_strafe_1.webp',
	'/landingpage/editiorial_strafe_2.webp',
	'/landingpage/editiorial_strafe_3.webp',
	'/landingpage/editiorial_strafe_4.webp',
	'/landingpage/editiorial_strafe_5.webp',
	'/landingpage/editiorial_strafe_6.webp',
];

const chosen = [
	{ closeUp: '/landingpage/close_up1.webp', product: '/landingpage/product1.webp', title:'DECK STAR BB', price:'120' },
	{ closeUp: '/landingpage/close_up2.webp', product: '/landingpage/product2.webp' },
	{ closeUp: '/landingpage/close_up3.webp', product: '/landingpage/product3.webp' },
	{ closeUp: '/landingpage/close_up4.webp', product: '/landingpage/product4.webp' },
	{ closeUp: '/landingpage/close_up5.webp', product: '/landingpage/product5.webp' },
	{ closeUp: '/landingpage/close_up6.webp', product: '/landingpage/product6.webp' },
];
---

<Layout title="strafe.shop">
	<section class="editorial-loop">
		<div class="editorial-track">
			{[...editorials, ...editorials].map((src) => (
				<img src={src} alt="" />
			))}
		</div>
		<div class="ediorial-track-options">
			<div class="ediorial-track-options-pause--resume">PAUSE</div>
			<div class="ediorial-track-options-faster">FASTER</div>
			<div class="ediorial-track-options-slower">SLOWER</div>
		</div>
	</section>
	<div class="chosen-products">
		{chosen.map((c) => (
			<div class="chosen-product">
				<img class="product-close" src={c.closeUp} alt="" />
				<img class="product-full" src={c.product} alt="" />
				<div class="product-info">
					<span class="title">{c.title}</span>
					<span>€{c.price}</span>
				</div>
			</div>
		))}
	</div>
	<div class="nav-start">
		<div class="logo"><img src='/landingpage/strafe_fullsize.png' alt="strafe"></div>
		<div class="meta">
			<span id="date"></span>
			<span id="time"></span>
			<span>BRL</span>
		</div>
	</div>
	<div class="links">
		<span>strafe.site</span>
		<a href="/collection">enter collection</a>
	</div>
</Layout>

<script>
	const track = document.querySelector('.editorial-track')!;
	const anim = track.getAnimations()[0];

	// der Track enthaelt die Bilder doppelt, also ist die Haelfte die echte Anzahl
	const count = track.children.length / 2;

	// manuell pausiert -> hover-leave soll nicht heimlich weiterlaufen lassen
	let paused = false;

	document.querySelectorAll('.chosen-product').forEach((el, i) => {
		el.addEventListener('mouseenter', () => {
			anim.pause();
			anim.currentTime = (i % count) / count * Number(anim.effect!.getTiming().duration);
		});

		el.addEventListener('mouseleave', () => { if (!paused) anim.play(); });
	});

	// track-optionen: pause/resume + tempo
	const pauseBtn = document.querySelector('.ediorial-track-options-pause--resume')!;
	pauseBtn.addEventListener('click', () => {
		paused = !paused;
		if (paused) anim.pause();
		else anim.play();
		pauseBtn.textContent = paused ? 'RESUME' : 'PAUSE';
	});

	// playbackRate ueberlebt pause/play, kollidiert also nicht mit dem hover-scrub
	document.querySelector('.ediorial-track-options-faster')!.addEventListener('click', () => { 
		anim.playbackRate *= 1.5; 
	});

	document.querySelector('.ediorial-track-options-slower')!.addEventListener('click', () => { 
		anim.playbackRate /= 1.5; 
	});

	// datum, zeit 
	const dateEl = document.getElementById('date')!;
	const timeEl = document.getElementById('time')!;

	const tick = () => {
		const now = new Date();
		dateEl.textContent = now.toLocaleDateString('de-DE', { timeZone: 'Europe/Berlin' });
		timeEl.textContent = now.toLocaleTimeString('de-DE', { timeZone: 'Europe/Berlin' });
	};

	tick();
	setInterval(tick, 1000);
</script>
