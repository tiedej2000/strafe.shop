---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products';
import Image from 'astro/components/Image.astro';

const path = Astro.url.pathname;
---

<Layout title="collection">
    <section class="collection">
        <div class="collection-grid" id="grid" style="--cols: 3">
            {products.map((p) => {
                const front = p.images.find((img) => img.type === 'front') ?? p.images[0];
                const modell = p.images.find((img) => img.type === 'modell');
                return (
                <a href={`/products/${p.id}`}>
                    <article class="product-card">
                        <img
                            src={front.src}
                            alt={front.alt}
                            data-front={front.src}
                            data-modell={modell?.src}
                            loading="lazy"
                        />
                        <div class="product-card-info hidden">
                            <span class="title">{p.title}</span>
                            <span class="price">€{p.price}</span>
                        </div>
                    </article>
                </a>
                );
            })}
        </div>
    </section>
    <div class="nav-collection">
        <div class="nav-main">
            <div class="main-icon"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M224,120v96a8,8,0,0,1-8,8H160a8,8,0,0,1-8-8V164a4,4,0,0,0-4-4H108a4,4,0,0,0-4,4v52a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V120a16,16,0,0,1,4.69-11.31l80-80a16,16,0,0,1,22.62,0l80,80A16,16,0,0,1,224,120Z"></path></svg></div>
        </div>
        <div class="nav-grid">
            <div class="grid-buttons">
                <div class="nav-button" id="min-btn"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M120,44V212a4,4,0,0,1-4,4H56a16,16,0,0,1-16-16V56A16,16,0,0,1,56,40h60A4,4,0,0,1,120,44Zm80-4H140a4,4,0,0,0-4,4V212a4,4,0,0,0,4,4h60a16,16,0,0,0,16-16V56A16,16,0,0,0,200,40Z"></path></svg>
                </div>
                <div class="nav-button active" id="mid-btn"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M216,56v60a4,4,0,0,1-4,4H136V44a4,4,0,0,1,4-4h60A16,16,0,0,1,216,56ZM116,40H56A16,16,0,0,0,40,56v60a4,4,0,0,0,4,4h76V44A4,4,0,0,0,116,40Zm96,96H136v76a4,4,0,0,0,4,4h60a16,16,0,0,0,16-16V140A4,4,0,0,0,212,136ZM40,140v60a16,16,0,0,0,16,16h60a4,4,0,0,0,4-4V136H44A4,4,0,0,0,40,140Z"></path></svg></div>
                <div class="nav-button" id="max-btn"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M84,52V92H28a4,4,0,0,1-4-4V64A16,16,0,0,1,40,48H80A4,4,0,0,1,84,52Zm16,152a4,4,0,0,0,4,4h48a4,4,0,0,0,4-4V164H100ZM24,168v24a16,16,0,0,0,16,16H80a4,4,0,0,0,4-4V164H28A4,4,0,0,0,24,168Zm0-56v32a4,4,0,0,0,4,4H84V108H28A4,4,0,0,0,24,112ZM152,48H104a4,4,0,0,0-4,4V92h56V52A4,4,0,0,0,152,48Zm76,60H172v40h56a4,4,0,0,0,4-4V112A4,4,0,0,0,228,108ZM100,148h56V108H100ZM216,48H176a4,4,0,0,0-4,4V92h56a4,4,0,0,0,4-4V64A16,16,0,0,0,216,48Zm12,116H172v40a4,4,0,0,0,4,4h40a16,16,0,0,0,16-16V168A4,4,0,0,0,228,164Z"></path></svg></div>
            </div>
            <div class="view-buttons">
                <div class="nav-button active" id="product-view"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M53.44,43.5,54.12,38A16,16,0,0,1,70,24H186a16,16,0,0,1,15.88,14l.68,5.49a4,4,0,0,1-4,4.5H57.41A4,4,0,0,1,53.44,43.5ZM169,64a32.06,32.06,0,0,0,31,24h3.59a4,4,0,0,0,4-4.5l-2-16a4,4,0,0,0-4-3.5ZM52.41,88H56A32.06,32.06,0,0,0,87,64H54.41a4,4,0,0,0-4,3.5l-2,16A4,4,0,0,0,52.41,88ZM223.88,214,210.56,107.5a4,4,0,0,0-4-3.5H200a48.07,48.07,0,0,1-47.32-40H136v39.73a8.18,8.18,0,0,1-7.47,8.25,8,8,0,0,1-8.53-8V64H103.32A48.07,48.07,0,0,1,56,104H49.41a4,4,0,0,0-4,3.5L32.12,214a16,16,0,0,0,6.71,15.09A16.56,16.56,0,0,0,48.39,232h40.3a16,16,0,0,0,15.51-12.06l23.8-92,23.79,91.94A16,16,0,0,0,167.31,232h40.3a16.54,16.54,0,0,0,9.56-2.89A16,16,0,0,0,223.88,214Z"></path></svg></div>
                <div class="nav-button" id="model-view"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M100,36a28,28,0,1,1,28,28A28,28,0,0,1,100,36ZM215.42,140.78l-45.25-51.3a28,28,0,0,0-21-9.48H106.83a28,28,0,0,0-21,9.48l-45.25,51.3a16,16,0,0,0,22.56,22.69L89,142.7l-19.7,74.88a16,16,0,0,0,29.08,13.35L128,180l29.58,51a16,16,0,0,0,29.08-13.35L167,142.7l25.9,20.77a16,16,0,0,0,22.56-22.69Z"></path></svg></div>
            </div>
            <div class="tag-buttons">
                <div class="nav-button active" id="tag-off"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M246.66,123.56,201,55.13A15.94,15.94,0,0,0,187.72,48H40A16,16,0,0,0,24,64V192a16,16,0,0,0,16,16H187.72A16,16,0,0,0,201,200.88l45.63-68.44A8,8,0,0,0,246.66,123.56ZM187.72,192H40V64H187.72l42.66,64Z"></path></svg></div>
                <div class="nav-button" id="tag-on"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M246.66,123.56,201,55.13A15.94,15.94,0,0,0,187.72,48H40A16,16,0,0,0,24,64V192a16,16,0,0,0,16,16H187.72A16,16,0,0,0,201,200.88h0l45.63-68.44A8,8,0,0,0,246.66,123.56Z"></path></svg></div>
            </div>
            <div class="info">
                <div class="nav-button" id="nav-expand"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M213.66,194.34A8,8,0,0,1,208,208H48a8,8,0,0,1-5.66-13.66L108.69,128H48a8,8,0,0,1-5.66-13.66l80-80a8,8,0,0,1,11.32,0l80,80A8,8,0,0,1,208,128H147.31Z"></path></svg></div>
            </div>
            <div class="nav-expanded" id="nav-panel">
                <div class="panel-section" data-panel="main">
                    <ul>
                        <li><a href="/" aria-current={path === '/' ? 'page' : undefined}>start</a></li>
                        <li><a href="/collection" aria-current={path === '/collection' ? 'page' : undefined}>collection</a></li>
                        <li><a href="/impressum" aria-current={path === '/impressum' ? 'page' : undefined}>impressum</a></li>
                    </ul>
                    <div class="titles"><span>strafe.site</span><span>site made by JT</span></div>
                </div>
                <div class="panel-section" data-panel="grid">
                    
                </div>
                <div class="panel-section" data-panel="cart">
                    
                </div>
            </div>
        </div>
        <div class="cart-expand-button"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M238,82.73A8,8,0,0,0,232,80H187.63L134,18.73a8,8,0,0,0-12,0L68.37,80H24a8,8,0,0,0-7.93,9.06L31.14,202.12A16.06,16.06,0,0,0,47,216H209a16.06,16.06,0,0,0,15.86-13.88L239.93,89.06A8,8,0,0,0,238,82.73ZM81.6,184a7.32,7.32,0,0,1-.81,0,8,8,0,0,1-8-7.2l-5.6-56a8,8,0,0,1,15.92-1.6l5.6,56A8,8,0,0,1,81.6,184Zm54.4-8a8,8,0,0,1-16,0V120a8,8,0,0,1,16,0ZM89.63,80,128,36.15,166.37,80Zm99.13,40.8-5.6,56a8,8,0,0,1-7.95,7.2,7.32,7.32,0,0,1-.81,0,8,8,0,0,1-7.16-8.76l5.6-56a8,8,0,0,1,15.92,1.6Z"></path></svg></div>

    </div>
</Layout>

<script>
import { navigate } from "astro:transitions/client";

    const grid = document.getElementById('grid')!;
    const gridBtns = document.querySelectorAll('.grid-buttons .nav-button');
    const viewBtns = document.querySelectorAll('.view-buttons .nav-button');
    const tagBtns = document.querySelectorAll('.tag-buttons .nav-button');


    //zuweisung active klassen im nav
    gridBtns.forEach((btn)=>{
        btn.addEventListener('click',() =>{
            gridBtns.forEach((b)=>{
                b.classList.remove('active')
            })
            btn.classList.add('active');
        })
    })

    viewBtns.forEach((btn)=>{
        btn.addEventListener('click',() =>{
            viewBtns.forEach((b)=>{
                b.classList.remove('active')
            })
            btn.classList.add('active');
        })
    })

    tagBtns.forEach((btn)=>{
        btn.addEventListener('click',() =>{
            tagBtns.forEach((b)=>{
                b.classList.remove('active')
            })
            btn.classList.add('active');
        })
    })

    // grid view änderung
    document.getElementById('min-btn')!.addEventListener('click', () => {
	    grid.style.setProperty('--cols', '2');
    });
    document.getElementById('mid-btn')!.addEventListener('click', () => {
	    grid.style.setProperty('--cols', '3');
    });
    document.getElementById('max-btn')!.addEventListener('click', () => {
	    grid.style.setProperty('--cols', '4');
    });

    const cardImages = document.querySelectorAll<HTMLImageElement>('.product-card img');

    // aktuelle Ansicht
    let currentView: 'front' | 'modell' = 'front';

    document.getElementById('product-view')!.addEventListener('click', () => {
        currentView = 'front';
        cardImages.forEach((img) => { img.src = img.dataset.front!; });
    });

    document.getElementById('model-view')!.addEventListener('click', () => {
        currentView = 'modell';
        cardImages.forEach((img) => {
            img.src = img.dataset.modell ?? img.dataset.front!;
        });
    });

    //product tags view
    const cardInfos = document.querySelectorAll('.product-card-info')

    document.getElementById('tag-off')!.addEventListener('click',()=>{
        cardInfos.forEach((card)=>{
            card.classList.add('hidden')
        })
    })

    document.getElementById('tag-on')!.addEventListener('click',()=>{
        cardInfos.forEach((card)=>{
            card.classList.remove('hidden')
        })
    })

    // modell bilder pre loaden
    cardImages.forEach((img) => {
        if (img.dataset.modell) {
            const pre = new Image();
            pre.src = img.dataset.modell;
        }
    });

    // wenn Modell img vorhanden zeige modell
    cardImages.forEach((img) => {
        const modell = img.dataset.modell;
        if (!modell) return;

        img.addEventListener('mouseenter', () => { img.src = modell; });
        img.addEventListener('mouseleave', () => {
            img.src = currentView === 'modell' ? modell : img.dataset.front!;
        });
    });

    // ein panel für alle: zeigt die gewählte sektion, gleicher klick schließt
    const navPanel = document.getElementById('nav-panel')!;

    function openPanel(name: string) {
        const section = navPanel.querySelector(`[data-panel="${name}"]`)!;
        const wasOpen = section.classList.contains('active');
        navPanel.querySelectorAll('.panel-section').forEach((s) => s.classList.remove('active'));
        navPanel.classList.toggle('active', !wasOpen);
        section.classList.toggle('active', !wasOpen);
    }

    document.querySelector('.main-icon')!.addEventListener('click', () => openPanel('main'));
    document.getElementById('nav-expand')!.addEventListener('click', () => openPanel('grid'));
    document.querySelector('.cart-expand-button')!.addEventListener('click', () => openPanel('cart'));

</script>