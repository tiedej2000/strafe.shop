---
import Layout from '../layouts/Layout.astro';

// Weitere Bilder einfach hier anhaengen
const editorials = [
	'/landingpage/editiorial_strafe_1.webp',
	'/landingpage/editiorial_strafe_2.webp',
	'/landingpage/editiorial_strafe_3.webp',
	'/landingpage/editiorial_strafe_4.webp',
	'/landingpage/editiorial_strafe_5.webp',
	'/landingpage/editiorial_strafe_6.webp',
];

const chosen = [
	{ closeUp: '/landingpage/close_up1.webp', product: '/landingpage/product1.webp', title:'DECK STAR BB', price:'120' },
	{ closeUp: '/landingpage/close_up2.webp', product: '/landingpage/product2.webp', title:'JEANS BAGGY ASPHALT', price:'120' },
	{ closeUp: '/landingpage/close_up3.webp', product: '/landingpage/product3.webp', title:'SHIRT DRK BW', price:'120' },
	{ closeUp: '/landingpage/close_up4.webp', product: '/landingpage/product4.webp', title:'SWEATER STR RED', price:'120' },
	{ closeUp: '/landingpage/close_up5.webp', product: '/landingpage/product5.webp', title:'BEANIE STAR BEIGE', price:'120' },
	{ closeUp: '/landingpage/close_up6.webp', product: '/landingpage/product6.webp', title:'COW BELT', price:'120' },
];
---

<Layout title="strafe.shop">
	<section class="editorial-loop">
		<div class="editorial-track">
			{[...editorials, ...editorials].map((src) => (
				<img src={src} alt="" decoding="async" />
			))}
		</div>
		<div class="options">
			<div class="color-changer">
				<div class="color" id="green"></div>
				<div class="color" id="blue"></div>
				<div class="color" id="red"></div>
				<div class="color" id="black"></div>
			</div>
			<div class="ediorial-track-options">
				<div class="ediorial-track-options-pause--resume">PAUSE</div>
				<div class="ediorial-track-options-faster">FASTER</div>
				<div class="ediorial-track-options-slower">SLOWER</div>
			</div>
		</div>
	</section>
	<div class="chosen-products">
		{chosen.map((c) => (
			<div class="chosen-product">
				<img class="product-close" src={c.closeUp} alt="" decoding="async" />
				<img class="product-full" src={c.product} alt="" loading="lazy" decoding="async" />
				<div class="product-info">
					<span class="title">{c.title}</span>
				</div>
			</div>
		))}
	</div>
	<div class="nav-start">
		<div class="meta">
			<span id="date"></span>
			<span id="time"></span>
			<span>BRL</span>
		</div>
	</div>
	<div class="links">
		<span>strafe.site</span>
		<a href="/collection">enter collection</a>
	</div>
</Layout>

<script>
	import { setColor } from '../scripts/color';

	// color changer
	const colorMessages: Record<string, string> = {
		green: 'my fav ;-)',
		blue: 'feeling blue',
		red: 'danger!!',
		black: 'ugh really?',
	};

	// color changer
	const dot = document.querySelector('.cursor-dot');
	const dotMeta = document.getElementById('dot-meta');
	document.querySelectorAll<HTMLElement>('.color-changer .color').forEach((sw) => {
		sw.addEventListener('click', () => setColor(sw.id));

		sw.addEventListener('mouseenter', () => {
			if (dotMeta) dotMeta.textContent = colorMessages[sw.id] ?? '';
			dot?.classList.add('active');
		});

		sw.addEventListener('mouseleave', () => {
			if (dotMeta) dotMeta.textContent = '';
			dot?.classList.remove('active');
		});
	});
	const track = document.querySelector('.editorial-track')!;

	// die scroll-animation vom track holen (nicht die transitions)
	function getAnim() {
		const anims = track.getAnimations() as CSSAnimation[];
		return anims.find(a => a.animationName === 'editorial-scroll');
	}

	// der Track enthaelt die Bilder doppelt
	const count = track.children.length / 2;

	let paused = false;

	document.querySelectorAll('.chosen-product').forEach((el, i) => {
		el.addEventListener('mouseenter', () => {
			const anim = getAnim();
			if (!anim) return;
			anim.pause();
			anim.currentTime = (i % count) / count * Number(anim.effect!.getTiming().duration);
		});

		el.addEventListener('mouseleave', () => { if (!paused) getAnim()?.play(); });
	});

	// track-optionen: pause/resume + tempo
	const pauseBtn = document.querySelector('.ediorial-track-options-pause--resume')!;
	pauseBtn.addEventListener('click', () => {
		const anim = getAnim();
		if (!anim) return;
		paused = !paused;
		if (paused) anim.pause();
		else anim.play();
		pauseBtn.textContent = paused ? 'RESUME' : 'PAUSE';
	});

	document.querySelector('.ediorial-track-options-faster')!.addEventListener('click', () => {
		const anim = getAnim();
		if (anim) anim.playbackRate *= 1.5;
	});

	document.querySelector('.ediorial-track-options-slower')!.addEventListener('click', () => {
		const anim = getAnim();
		if (anim) anim.playbackRate /= 1.5;
	});

	// datum, zeit 
	const dateEl = document.getElementById('date')!;
	const timeEl = document.getElementById('time')!;

	const tick = () => {
		const now = new Date();
		dateEl.textContent = now.toLocaleDateString('de-DE', { timeZone: 'Europe/Berlin' });
		timeEl.textContent = now.toLocaleTimeString('de-DE', { timeZone: 'Europe/Berlin' });
	};

	tick();
	setInterval(tick, 1000);

	// füge dem dot die click klasse hinzu
    window.addEventListener('click', () => {
        dot?.classList.add('click');
        setTimeout(() => dot?.classList.remove('click'), 400);
    });
</script>
