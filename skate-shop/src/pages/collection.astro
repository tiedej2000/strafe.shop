---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products';
import Image from 'astro/components/Image.astro';

const path = Astro.url.pathname;

// anzeige-reihenfolge der kategorien – einfach umsortieren
const categoryOrder = [
	'tops',
	'bottoms',
	'accessories',
	'gear',
	'collectible',
];

// unbekannte kategorien ans ende statt (durch indexOf -1) an den anfang
const pos = (c: string) => {
	const i = categoryOrder.indexOf(c);
	return i === -1 ? categoryOrder.length : i;
};

const sortedProducts = [...products].sort((a, b) => pos(a.category) - pos(b.category));
---

<Layout title="collection">
    <section class="collection">
        <div class="collection-grid single" id="grid">
            {sortedProducts.map((p) => {
                const front = p.images.find((img) => img.type === 'front') ?? p.images[0];
                const modell = p.images.find((img) => img.type === 'modell');
    
                const shots = p.images.filter((img) => img !== front); 
                return (
                <a href={`/products/${p.id}`}>
                    <article class="product-card">
                        <div class="product-img">
                            <img
                                src={modell?.src ?? front.src}
                                alt={modell?.alt ?? front.alt}
                                data-front={front.src}
                                data-modell={modell?.src}
                                loading="lazy"
                            />
                            <div class="product-shots">
                                {shots.map((s) => (
                                    <img src={s.src} alt={s.alt} loading="lazy" />
                                ))}
                            </div>
                        </div>
                        <div class="product-card-info hidden">
                            <span class="title">{p.title}</span>
                            <span class="price">€{p.price}</span>
                        </div>
                        
                    </article>
                </a>
                );
            })}
        </div>
        <div class="back-button" id="back-button-start"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M205.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L131.31,128ZM51.31,128l74.35-74.34a8,8,0,0,0-11.32-11.32l-80,80a8,8,0,0,0,0,11.32l80,80a8,8,0,0,0,11.32-11.32Z"></path></svg></div>
    </section>
    <div class="nav-collection">
        <div class="nav-main">
            <div class="main-icon">menu</div>
        </div>
        <div class="nav-grid">
            <div class="grid-buttons">
                <div class="nav-button active" id="single-btn">1col</div>
                <div class="nav-button" id="min-btn">3col</div>
                <div class="nav-button " id="mid-btn">4col</div>
                <div class="nav-button" id="max-btn">5col</div>
            </div>
            <div class="view-buttons">
                <div class="nav-button" id="product-view">flat</div>
                <div class="nav-button active" id="model-view">worn</div>
            </div>
            <div class="tag-buttons">
                <div class="nav-button active" id="tag-off">hide tags</div>
                <div class="nav-button" id="tag-on">show tags</div>
            </div>
            <div class="info">
                <div class="nav-button" id="nav-expand">more</div>
            </div>
            <div class="nav-expanded" id="nav-panel">
                <div class="panel-section" data-panel="main">
                    <img src="/collection/banner_menu.webp" alt="">
                    <ul>
                        <li><a href="/" aria-current={path === '/' ? 'page' : undefined}>start</a></li>
                        <li><a href="/collection" aria-current={path === '/collection' ? 'page' : undefined}>collection</a></li>
                        <li><a href="/impressum" aria-current={path === '/impressum' ? 'page' : undefined}>impressum</a></li>
                    </ul>
                    <div class="titles"><span>strafe.site</span><span> made by JT</span></div>
                </div>
                <div class="panel-section" data-panel="grid">
                    
                </div>
                <div class="panel-section" data-panel="cart">
                    
                </div>
            </div>
        </div>
        <div class="cart-expand-button">cart</div>
    </div>
</Layout>

<script>
import { navigate } from "astro:transitions/client";
import { products } from '../data/products';
import { initCartUI } from '../scripts/cart';

    const grid = document.getElementById('grid')!;
    const gridBtns = document.querySelectorAll('.grid-buttons .nav-button');
    const viewBtns = document.querySelectorAll('.view-buttons .nav-button');
    const tagBtns = document.querySelectorAll('.tag-buttons .nav-button');


    //zuweisung active klassen im nav
    gridBtns.forEach((btn)=>{
        btn.addEventListener('click',() =>{
            gridBtns.forEach((b)=>{
                b.classList.remove('active')
            })
            btn.classList.add('active');
        })
    })

    viewBtns.forEach((btn)=>{
        btn.addEventListener('click',() =>{
            viewBtns.forEach((b)=>{
                b.classList.remove('active')
            })
            btn.classList.add('active');
        })
    })

    tagBtns.forEach((btn)=>{
        btn.addEventListener('click',() =>{
            tagBtns.forEach((b)=>{
                b.classList.remove('active')
            })
            btn.classList.add('active');
        })
    })

    // grid view änderung
    document.getElementById('single-btn')!.addEventListener('click', () => {
	    grid.classList.add('single');
	    // overflow:hidden friert den alten scroll-offset ein -> explizit nach oben
	    window.scrollTo({ top: 0, behavior: 'instant' });
    });
    document.getElementById('min-btn')!.addEventListener('click', () => {
	    grid.classList.remove('single');
	    grid.style.setProperty('--cols', '3');
    });
    document.getElementById('mid-btn')!.addEventListener('click', () => {
	    grid.classList.remove('single');
	    grid.style.setProperty('--cols', '4');
    });
    document.getElementById('max-btn')!.addEventListener('click', () => {
	    grid.classList.remove('single');
	    grid.style.setProperty('--cols', '5');
    });

    // wenn single view, mappe vertical scroll auf horizontal
    grid.addEventListener('wheel', (e) => {
        if (!grid.classList.contains('single') || e.deltaY === 0) return;
        e.preventDefault();
        grid.scrollLeft += e.deltaY;
    }, { passive: false });

    
    const cardImages = document.querySelectorAll<HTMLImageElement>('.product-img > img');

    // aktuelle Ansicht 
    let currentView: 'front' | 'modell' = 'modell';

    document.getElementById('product-view')!.addEventListener('click', () => {
        currentView = 'front';
        cardImages.forEach((img) => { img.src = img.dataset.front!; });
    });

    document.getElementById('model-view')!.addEventListener('click', () => {
        currentView = 'modell';
        cardImages.forEach((img) => {
            img.src = img.dataset.modell ?? img.dataset.front!;
        });
    });

    //product tags view
    const cardInfos = document.querySelectorAll('.product-card-info')

    document.getElementById('tag-off')!.addEventListener('click',()=>{
        cardInfos.forEach((card)=>{
            card.classList.add('hidden')
        })
    })

    document.getElementById('tag-on')!.addEventListener('click',()=>{
        cardInfos.forEach((card)=>{
            card.classList.remove('hidden')
        })
    })


    // beim hovern eines produktbilds den titel in die cursor-meta schreiben
    const dotMeta = document.getElementById('dot-meta');
    const dot = document.querySelector('.cursor-dot');

    document.querySelectorAll<HTMLElement>('.product-card').forEach((card) => {
        const img = card.querySelector<HTMLElement>('.product-img');
        const title = card.querySelector('.title')?.textContent ?? '';
        if (!img || !dotMeta) return;

        img.addEventListener('mouseenter', () => { 
            dotMeta.textContent = title;
            dot?.classList.add('active');
        });
        img.addEventListener('mouseleave', () => { 
            dotMeta.textContent = ''; 
            dot?.classList.remove('active');
        });
    });

    //back button
    const backBtn = document.getElementById('back-button-start')
    backBtn?.addEventListener('click', () =>{
        navigate('/');
    })

    backBtn?.addEventListener('mouseenter', () => { 
        dotMeta.textContent = 'back';
        dot?.classList.add('active');
    });

    backBtn?.addEventListener('mouseleave', () => { 
        dotMeta.textContent = '';
        dot?.classList.remove('active');
    });

    // panel based on welches menü
    const navPanel = document.getElementById('nav-panel')!;

    function openPanel(name: string) {
        const section = navPanel.querySelector(`[data-panel="${name}"]`)!;
        const wasOpen = section.classList.contains('active');
        navPanel.querySelectorAll('.panel-section').forEach((s) => s.classList.remove('active'));
        navPanel.classList.toggle('active', !wasOpen);
        section.classList.toggle('active', !wasOpen);
    }

    document.getElementById('nav-expand')!.addEventListener('click', () => 
        openPanel('grid')
    );

    const menuBtn = document.querySelector('.main-icon')!;
    menuBtn.addEventListener('click', () => {
        openPanel('main');
        menuBtn.classList.toggle('active');
    });

    const cartBtn = document.querySelector('.cart-expand-button')!;
    cartBtn.addEventListener('click', () => {
        openPanel('cart');
        cartBtn.classList.toggle('active');
    });

    // ---- cart panel (gemeinsames rendering aus cart.ts) ----
    initCartUI(
        navPanel.querySelector<HTMLElement>('[data-panel="cart"]')!,
        cartBtn as HTMLElement,
        products,
    );

</script>