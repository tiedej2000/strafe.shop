---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';

export function getStaticPaths() {
	return products.map((p) => ({
		params: { id: p.id },
		props: { product: p },
	}));
}

const { product } = Astro.props;
const path = Astro.url.pathname;
---

<Layout title={product.title}>
	<section class="product-page">
		<div class="product-details">
			<div class="details">
				<span class="id">{product.id}</span>
				<span class="title">{product.title}</span>
				<span class="price">€ {product.price}</span>
			</div>
		</div>
		<div class="product-images">
			{product.images.map((img) => (
				<img src={img.src} alt={img.alt} />
			))}
		</div>
        <div class="back-button" id="back-button-collection"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M205.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L131.31,128ZM51.31,128l74.35-74.34a8,8,0,0,0-11.32-11.32l-80,80a8,8,0,0,0,0,11.32l80,80a8,8,0,0,0,11.32-11.32Z"></path></svg></div>

		<div class="size-picker-wrapper">
			{product.sizes && (
				<div class="size-picker" id="size-picker">
					{product.sizes.map((s) => (
						<button class="size-option" data-size={s}>{s}</button>
					))}
				</div>
			)}
			<button class="add-to-cart" id="add-to-cart" data-id={product.id}>{product.sizes ? 'choose size' : 'add to cart'}</button>
		</div>
	</section>
	<div class="nav-products">
        <div class="nav-main">
            <div class="main-icon">menu</div>
        </div>
        <div class="nav-product">
            <div class="product-buttons">
                <div class="nav-button" data-panel="description">description</div>
            </div>
            <div class="product-buttons">
                <div class="nav-button" data-panel="details">details</div>
            </div>
            <div class="product-buttons">
                <div class="nav-button" data-panel="care">care</div>
            </div>
            <div class="product-buttons">
                <div class="nav-button" data-panel="size">size guide</div>
            </div>
            <div class="nav-expanded" id="nav-panel">
                <div class="panel-section" data-panel="main">
                    <img src="/collection/banner_menu.webp" alt="">
                    <ul>
                        <li><a href="/" aria-current={path === '/' ? 'page' : undefined}>start</a></li>
                        <li><a href="/collection" aria-current={path === '/collection' ? 'page' : undefined}>collection</a></li>
                        <li><a href="/impressum" aria-current={path === '/impressum' ? 'page' : undefined}>impressum</a></li>
                    </ul>
                    <div class="titles"><span>strafe.site</span><span> made by JT</span></div>
                </div>

                <div class="panel-section" data-panel="description">{product.description}</div>
                <div class="panel-section" data-panel="details">{product.productDetails}</div>
                <div class="panel-section" data-panel="care">{product.productCare}</div>
                <div class="panel-section" data-panel="size">
                    <div class="size-row"><span>size</span><span>chest</span><span>length</span></div>
                    <div class="size-row"><span>s</span><span>54 cm</span><span>68 cm</span></div>
                    <div class="size-row"><span>m</span><span>57 cm</span><span>70 cm</span></div>
                    <div class="size-row"><span>l</span><span>60 cm</span><span>72 cm</span></div>
                    <div class="size-row"><span>xl</span><span>63 cm</span><span>74 cm</span></div>
                </div>

                <div class="panel-section" data-panel="cart"></div>
            </div>
        </div>
        <div class="cart-expand-button">cart (0)</div>
    </div>
</Layout>

<script>
	import { addToCart, initCartUI } from '../../scripts/cart';
	import { products } from '../../data/products';
	import { navigate } from "astro:transitions/client";

	const btn = document.getElementById('add-to-cart')!;
	const sizePicker = document.getElementById('size-picker');

	const sizeOptions = sizePicker
		? [...sizePicker.querySelectorAll<HTMLElement>('.size-option')]
		: [];
	let selectedSize: string | undefined;

	const resetPicker = () => {
		sizePicker?.classList.remove('open');
		sizeOptions.forEach((o) => o.classList.remove('selected'));
		selectedSize = undefined;
		if (sizePicker) btn.textContent = 'choose size';
	};

	btn.addEventListener('click', () => {
		if (!sizePicker) {
			addToCart(btn.dataset.id!);
			btn.textContent = 'added';
			setTimeout(() => { btn.textContent = 'add to cart'; }, 800);
			return;
		}

		if (!sizePicker.classList.contains('open')) {
			sizePicker.classList.add('open');
			return;
		}

		if (!selectedSize) {
			sizePicker.classList.remove('open');
			return;
		}

		addToCart(btn.dataset.id!, selectedSize);
		resetPicker();
		btn.textContent = 'added';
		setTimeout(() => { btn.textContent = 'choose size'; }, 800);
	});

	sizeOptions.forEach((o) => {
		o.addEventListener('click', () => {
			sizeOptions.forEach((s) => s.classList.remove('selected'));
			o.classList.add('selected');
			selectedSize = o.dataset.size;
			btn.textContent = 'add to cart';
		});
	});

	// vertikales mausrad auf horizontales scrollen der bilder mappen
	const imagesEl = document.querySelector<HTMLElement>('.product-images')!;
	imagesEl.addEventListener('wheel', (e) => {
		if (e.deltaY === 0) return;
		e.preventDefault();
		imagesEl.scrollLeft += e.deltaY;
	}, { passive: false });

	const dotMeta = document.getElementById('dot-meta');
	const dot = document.querySelector('.cursor-dot');

	imagesEl.querySelectorAll('img').forEach((img) => {
		img.addEventListener('mouseenter', () => {
			if (dotMeta) dotMeta.textContent = 'add to cart';
			dot?.classList.add('active');
		});

		img.addEventListener('mouseleave', () => {
			if (dotMeta) dotMeta.textContent = '';
			dot?.classList.remove('active');
		});

		img.addEventListener('click', () => {
			// option A: mit groessen oeffnet der bild-klick den size-picker
			if (sizePicker) {
				sizePicker.classList.add('open');
				if (dotMeta) dotMeta.textContent = 'choose size';
				return;
			}

			addToCart(btn.dataset.id!);
			if (dotMeta) {
				dotMeta.textContent = 'added';
				setTimeout(() => {
					if (dotMeta.textContent === 'added') dotMeta.textContent = 'add to cart';
				}, 800);
			}
		});
	});

	// ein panel für alle: zeigt die gewählte sektion, gleicher klick schließt
	const navPanel = document.getElementById('nav-panel')!;

	function openPanel(name: string) {
		const section = navPanel.querySelector(`[data-panel="${name}"]`)!;
		const wasOpen = section.classList.contains('active');
		navPanel.querySelectorAll('.panel-section').forEach((s) => s.classList.remove('active'));
		navPanel.classList.toggle('active', !wasOpen);
		section.classList.toggle('active', !wasOpen);
		return !wasOpen;
	}

	// produkt-info buttons: oeffnen ihre sektion, active folgt dem panel-zustand
	const infoBtns = document.querySelectorAll<HTMLElement>('.product-buttons .nav-button');

	infoBtns.forEach((b) => {
		b.addEventListener('click', () => {
			const offen = openPanel(b.dataset.panel!);
			infoBtns.forEach((o) => o.classList.remove('active'));
			b.classList.toggle('active', offen);
		});
	});

	document.querySelector('.main-icon')!.addEventListener('click', () => 
		openPanel('main')
	);
	document.querySelector('.cart-expand-button')!.addEventListener('click', () => 
	openPanel('cart')
	);

	// cart panel (gemeinsames rendering aus cart.ts)
	initCartUI(
		navPanel.querySelector<HTMLElement>('[data-panel="cart"]')!,
		document.querySelector<HTMLElement>('.cart-expand-button')!,
		products,
	);

	// back button (dotMeta/dot sind oben schon deklariert)
    const backBtn = document.getElementById('back-button-collection')
    backBtn?.addEventListener('click', () =>{
        navigate('/collection');
    })

    backBtn?.addEventListener('mouseenter', () => {
        if (dotMeta) dotMeta.textContent = 'back';
        dot?.classList.add('active');
    });

    backBtn?.addEventListener('mouseleave', () => {
        if (dotMeta) dotMeta.textContent = '';
        dot?.classList.remove('active');
    });

	// füge dem dot die click klasse hinzu
    window.addEventListener('click', () => {
        dot?.classList.add('click');
        setTimeout(() => dot?.classList.remove('click'), 400);
    });
</script>